# ===========================================
# BossBrainz Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# See lib/env.ts for validation rules

# ---- Required ----
AUTH_SECRET=                          # Min 32 chars, used for CSRF security
OPENROUTER_API_KEY=                   # OpenRouter API key for AI models
SUPABASE_SERVICE_ROLE_KEY=            # Supabase service role key (server-side only, NEVER expose)
NEXT_PUBLIC_APP_URL=https://bossbrainz.aleccimedia.com  # Production URL, no trailing slash
NEXT_PUBLIC_SUPABASE_URL=             # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Supabase anon key (RLS enforces security)

# ---- Payments (Stripe) ----
STRIPE_SECRET_KEY=                    # Stripe API key (server-side only)
STRIPE_WEBHOOK_SECRET=                # Stripe webhook signing secret
STRIPE_PRICE_MONTHLY=                 # Stripe price ID for monthly plan
STRIPE_PRICE_ANNUAL=                  # Stripe price ID for annual plan
STRIPE_PRICE_LIFETIME=                # Stripe price ID for lifetime plan
STRIPE_PORTAL_CONFIG_ID=              # Stripe customer portal config

# ---- Voice (ElevenLabs) ----
ELEVENLABS_API_KEY=                   # ElevenLabs TTS API key
ELEVENLABS_VOICE_ID_ALEXANDRIA=       # Voice ID for Alexandria persona
ELEVENLABS_VOICE_ID_KIM=             # Voice ID for Kim persona

# ---- Search ----
TAVILY_API_KEY=                       # Tavily web search
SERPER_API_KEY=                       # Serper search API

# ---- Storage ----
BLOB_READ_WRITE_TOKEN=                # Vercel Blob storage

# ---- Caching / Streams ----
REDIS_URL=                            # Redis for rate limiting + resumable streams

# ---- Observability ----
SENTRY_DSN=                           # Sentry server-side DSN
SENTRY_AUTH_TOKEN=                    # Sentry auth token for source maps
NEXT_PUBLIC_SENTRY_DSN=               # Sentry client-side DSN
LOG_LEVEL=info                        # fatal | error | warn | info | debug | trace

# ---- Email (Mailchimp / Mandrill) ----
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=
MANDRILL_API_KEY=
MANDRILL_FROM_EMAIL=

# ---- Cron ----
CRON_SECRET=                          # Secret for cron job authentication

# ---- Integrations ----
FIREFLIES_API_KEY=                    # Fireflies.ai meeting transcription

# ---- Testing (do not set in production) ----
# PLAYWRIGHT=True
# CI_PLAYWRIGHT=True
# PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000
